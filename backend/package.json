{
  "name": "portfolio-backend",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=.env watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "drop": "tsx --env-file=.env src/database/drop.ts",
    "generate": "drizzle-kit generate",
    "migrate": "tsx --env-file=.env src/database/migrate.ts",
    "seed": "tsx --env-file=.env src/database/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.31.2",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "postgres": "^3.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.9",
    "drizzle-kit": "^0.22.7",
    "tsx": "^4.16.2",
    "typescript": "^5.4.5"
  }
}
